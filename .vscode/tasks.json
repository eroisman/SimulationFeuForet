{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Maven: Build",
      "type": "shell",
      "command": "mvn",
      "args": [
        "clean",
        "compile"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$javac"
      ]
    },
    {
      "label": "Maven: Run JavaFX",
      "type": "shell",
      "command": "mvn",
      "args": [
        "javafx:run"
      ],
      "problemMatcher": []
    }
  ]
}
